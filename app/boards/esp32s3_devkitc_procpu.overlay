#include <zephyr/dt-bindings/led/led.h>
#include <zephyr/dt-bindings/pinctrl/esp32s3-pinctrl.h>

/ {
    chosen {
        zephyr,console = &cdc_acm_uart0;
        zephyr,shell-uart = &cdc_acm_uart0;
    };

    /* STA-REQ-01: Alias fuer RGB-LED-Strip */
    aliases {
        led-strip = &led_strip;
    };
};

/* STA-REQ-01: Pinctrl fuer SPI3 MOSI auf GPIO 48 (WS2812 RGB-LED) */
&pinctrl {
    spim3_ws2812: spim3_ws2812 {
        group1 {
            pinmux = <SPIM3_MOSI_GPIO48>;
            output-enable;
        };
    };
};

/* STA-REQ-01: SPI3 als WS2812-Treiber auf GPIO 48 */
&spi3 {
    pinctrl-0 = <&spim3_ws2812>;
    pinctrl-names = "default";
    line-idle-low;

    led_strip: ws2812@0 {
        compatible = "worldsemi,ws2812-spi";
        reg = <0>;
        spi-max-frequency = <6400000>;
        chain-length = <1>;
        spi-cpha;
        /* WS2812: 1-Bit = 4 High + 4 Low, 0-Bit = 2 High + 6 Low bei 6.4 MHz */
        spi-one-frame = <0xf0>;
        spi-zero-frame = <0xc0>;
        /* WS2812 sendet in GRB-Reihenfolge */
        color-mapping = <LED_COLOR_ID_GREEN
                         LED_COLOR_ID_RED
                         LED_COLOR_ID_BLUE>;
    };
};

&zephyr_udc0 {
    cdc_acm_uart0: cdc_acm_uart0 {
        compatible = "zephyr,cdc-acm-uart";
    };
};
